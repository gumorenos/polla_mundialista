# ============================================================
# Oráculo Mundial 2026 — Variables de entorno
# Copiar a .env y completar valores reales.
# NUNCA commitear .env al repositorio.
# ============================================================

# ---------------------------
# Base de datos
# ---------------------------
SQLITE_PATH=data/sqlite/oraculo.db

# ---------------------------
# Logging
# ---------------------------
LOG_FILE=data/oraculo.log
LOG_LEVEL=INFO

# ---------------------------
# Redis / RQ
# ---------------------------
REDIS_URL=redis://redis:6379/0
RQ_DEFAULT_TIMEOUT=3600
RQ_LONG_TIMEOUT=7200

# ---------------------------
# API Football — obtener en https://www.api-football.com/
# ---------------------------
API_FOOTBALL_KEY=
# Cuenta directa en api-sports.io (default):
#   API_FOOTBALL_RAPIDAPI=false  → header x-apisports-key
# Cuenta vía RapidAPI:
#   API_FOOTBALL_RAPIDAPI=true   → headers x-rapidapi-key + x-rapidapi-host
API_FOOTBALL_RAPIDAPI=false
API_FOOTBALL_HOST=v3.football.api-sports.io

# ---------------------------
# football-data.org — backup de API-Football
# Obtener en https://www.football-data.org/client/register (tier gratuito disponible)
# Si no está configurada, se salta este paso y se usa CSV como fallback.
# ---------------------------
FOOTBALL_DATA_API_KEY=

# ---------------------------
# OpenRouter / LLM
# ---------------------------
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SITE_URL=https://your-app-url.com
OPENROUTER_APP_NAME=OraculoMundial2026

# ---------------------------
# Seguridad
# ---------------------------
# ── Seguridad ────────────────────────────────────────────────────────
# Token para API directa (curl, scripts, acceso sin UI)
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
ADMIN_TOKEN=change_me_in_production

# Contraseña para login web (más amigable, ej: tunombre2026)
# Se puede rotar actualizando este valor y reiniciando el contenedor
ADMIN_PASSWORD=change_me_in_production

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limiting (slowapi) — requests por minuto
RATE_LIMIT_PUBLIC=60/minute
RATE_LIMIT_ADMIN=10/minute

# ---------------------------
# Modelos estadísticos
# ---------------------------
TIME_DECAY_FACTOR=0.001
POISSON_MAX_GOALS=8
DIXON_COLES_RHO=0.15
LOCAL_ADVANTAGE_NEUTRAL=1.0
LOCAL_ADVANTAGE_HOME=1.1

# ---------------------------
# Lesiones / Noticias
# ---------------------------
INJURY_ATTACK_PENALTY=0.15
INJURY_DEFENSE_PENALTY=0.05
NEWS_MIN_SOURCES=2
NEWS_CONFIDENCE_THRESHOLD=0.7
NEWS_MAX_PER_PLAYER=5
NEWS_DAYS_LOOKBACK=7

# ---------------------------
# Monte Carlo
# ---------------------------
MONTECARLO_ITERATIONS=30000
MONTECARLO_SEED=42
SIMULATION_BATCH_SIZE=1000

# ---------------------------
# Machine Learning
# ---------------------------
ML_TRAIN_START_YEAR=2010
ML_VALIDATION_SPLIT=0.2
ML_PREFERRED_ALGORITHM=lightgbm

# ---------------------------
# Scheduler (cron expresiones)
# ---------------------------
SCHEDULER_FULL_REFRESH_CRON=0 3 * * *
SCHEDULER_NEWS_CRON=0 */6 * * *

# ---------------------------
# Fuentes confiables para noticias
# ---------------------------
FUENTES_CONFIABLES=espn.com,marca.com,theathletic.com,bbc.com,goal.com

# ---------------------------
# Entorno
# ---------------------------
ENVIRONMENT=development
DEBUG=false

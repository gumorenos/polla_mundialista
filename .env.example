# ============================================================
# Oráculo Mundial 2026 — Variables de entorno
# Copiar a .env y completar valores reales.
# NUNCA commitear .env al repositorio.
# ============================================================

# ---------------------------
# Base de datos
# ---------------------------
SQLITE_PATH=data/sqlite/oraculo.db

# ---------------------------
# Logging
# ---------------------------
LOG_FILE=data/oraculo.log
LOG_LEVEL=INFO

# ---------------------------
# Redis / RQ
# ---------------------------
REDIS_URL=redis://redis:6379/0
RQ_DEFAULT_TIMEOUT=3600
RQ_LONG_TIMEOUT=7200

# ---------------------------
# API Football (api-sports.io)
# ---------------------------
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io/

# ---------------------------
# OpenRouter / LLM
# ---------------------------
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPENROUTER_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_SITE_URL=https://your-app-url.com
OPENROUTER_APP_NAME=OraculoMundial2026

# ---------------------------
# Seguridad
# ---------------------------
# Token para endpoints /admin — requerido en producción
ADMIN_TOKEN=change_me_in_production

# Orígenes CORS permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---------------------------
# Modelos estadísticos
# ---------------------------
TIME_DECAY_FACTOR=0.001
POISSON_MAX_GOALS=8
DIXON_COLES_RHO=0.15
LOCAL_ADVANTAGE_NEUTRAL=1.0
LOCAL_ADVANTAGE_HOME=1.1

# ---------------------------
# Lesiones / Noticias
# ---------------------------
INJURY_ATTACK_PENALTY=0.15
INJURY_DEFENSE_PENALTY=0.05
NEWS_MIN_SOURCES=2
NEWS_CONFIDENCE_THRESHOLD=0.7
NEWS_MAX_PER_PLAYER=5
NEWS_DAYS_LOOKBACK=7

# ---------------------------
# Monte Carlo
# ---------------------------
MONTECARLO_ITERATIONS=30000
MONTECARLO_SEED=42
SIMULATION_BATCH_SIZE=1000

# ---------------------------
# Machine Learning
# ---------------------------
ML_TRAIN_START_YEAR=2010
ML_VALIDATION_SPLIT=0.2
ML_PREFERRED_ALGORITHM=lightgbm

# ---------------------------
# Scheduler (cron expresiones)
# ---------------------------
SCHEDULER_FULL_REFRESH_CRON=0 3 * * *
SCHEDULER_NEWS_CRON=0 */6 * * *

# ---------------------------
# Fuentes confiables para noticias
# ---------------------------
FUENTES_CONFIABLES=espn.com,marca.com,theathletic.com,bbc.com,goal.com

# ---------------------------
# Entorno
# ---------------------------
ENVIRONMENT=development
DEBUG=false
